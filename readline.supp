   match-leak-kinds: reachable
   ...
   obj:*/libreadline.so.*
}

{
   readline_leak_2
   Memcheck:Leak
   match-leak-kinds: reachable
   ...
   fun:readline
}

{
   readline_leak_3
   Memcheck:Leak
   match-leak-kinds: reachable
   ...
   fun:add_history
}

{
   readline_leak_ioctl
   Memcheck:Param
   ioctl(generic)
   fun:ioctl
   obj:*/libreadline.so*
}
